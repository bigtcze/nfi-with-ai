# cliproxy endpoint (ChatGPT subscription via CLI proxy)
LLM_BASE_URL=http://localhost:8317/v1
# cliproxy API key (sent as "Authorization: Bearer <key>"); leave empty if cliproxy needs no auth
LLM_API_KEY=
# GPT model name exposed by cliproxy
LLM_MODEL=gpt-5.4-mini
# cliproxy / OpenAI-compatible reasoning effort
# Keep "medium" as default: "high" makes the model reason long on every single
# review (even trivial ones), raising latency and the chance of a timeout exactly
# on the borderline charts where judgement matters most.
LLM_REASONING_EFFORT=medium
# 20s timeout - fail-open if GPT doesn't respond in time. Entries are limit
# orders with a multi-minute unfilledtimeout, so the opportunity window is wide;
# 20s leaves room for reasoning without blocking the Freqtrade loop too long.
LLM_TIMEOUT=20
# Max completion tokens. Set high enough that reasoning tokens plus the final
# JSON both fit, otherwise the JSON gets truncated and the trade fails open.
LLM_MAX_TOKENS=16384
# 60s cooldown - one review per pair per cycle on 5m candles with 80 pairs
LLM_COOLDOWN=60

# Freqtrade config points to strategy "NFIWithVeto"
